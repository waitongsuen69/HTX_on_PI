{
  "name": "htx-pi-monitor",
  "version": "1.0.0",
  "description": "HTX cryptocurrency portfolio monitor for Raspberry Pi",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "dev:clean": "npm run kill-port && npm run dev",
    "kill-port": "lsof -ti:8080 | xargs kill -9 2>/dev/null || echo 'Port 8080 cleared'",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "jest --testPathPattern=e2e --runInBand",
    "test:stress": "node test/stress/runner.js",
    "test:mock-server": "node test/mocks/htx-mock-server.js"
  },
  "dependencies": {
    "express": "^4.19.0",
    "axios": "^1.7.0",
    "dotenv": "^16.4.0",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.0",
    "nock": "^13.5.0",
    "@types/jest": "^29.5.0",
    "cross-env": "^7.0.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "cryptocurrency",
    "portfolio",
    "raspberry-pi",
    "htx",
    "monitor",
    "trading"
  ],
  "author": "HTX Pi Monitor",
  "license": "MIT"
}